{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "open-in-emacs",
			"type": "process",
			"command": "myemacs",
			"args": ["-c", "${file}"],
			"presentation": {
				"reveal": "never",
				"panel": "dedicated",
				"echo": false,
				"showReuseMessage": false,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "open-alacritty-here",
			"type": "process",
			"command": "alacritty",
			"options": { "cwd": "${fileDirname}" },
			"presentation": {
				"reveal": "never",
				"panel": "dedicated",
				"echo": false,
				"showReuseMessage": false,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "open-magit-here",
			"type": "process",
			"command": "magit",
			"options": { "cwd": "${fileDirname}" },
			"presentation": {
				"reveal": "never",
				"panel": "dedicated",
				"echo": false,
				"showReuseMessage": false,
				"close": true
			},
			"problemMatcher": []
		},
		{
			"label": "toggle-snapshot",
			"type": "shell",
			"command": "bash",
			"args": [
				"-c",
				"f=\"$1\"; if [[ \"$f\" == *.snap ]]; then dir=\"$(dirname \"$f\")\"; base=\"$(basename \"$f\" .snap)\"; target=\"$(dirname \"$dir\")/$base\"; else target=\"$(dirname \"$f\")/__snapshots__/$(basename \"$f\").snap\"; fi; vscode -r \"$target\"",
				"--",
				"${file}"
			],
			"presentation": {
				"reveal": "never",
				"panel": "dedicated",
				"echo": false,
				"showReuseMessage": false,
				"close": false
			},
			"problemMatcher": []
		}
	]
}
