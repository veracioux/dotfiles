# -*- mode: ruby -*-
# vi: set ft=ruby :

VAGRANT_COMMAND = ARGV[0]
DEFAULT_RESOLUTION = "1920x1080"
VIDEO_MODES = [
  "1920x1080x32",
  "1600x900x32",
  "1440x900x32",
  "1366x768x32",
  "1280x800x32"
]

Vagrant.configure("2") do |config|
  # Arch Linux box
 config.vm.box = "Kppqju77/arch"

  # VM Name
 config.vm.define "dev-playground"

  # SSH configuration
  if VAGRANT_COMMAND == "ssh"
    config.ssh.username = "haris"
  end

  # Network configuration
  config.vm.network "private_network", type: "dhcp"

  # Hostname
  config.vm.hostname = "dev-playground"

  # Synced folder (optional, can customize)
  config.vm.synced_folder ".", "/vagrant", disabled: false

  # Provider-specific configuration
  config.vm.provider "virtualbox" do |vb|
    # Display the VirtualBox GUI when booting the machine
    vb.gui = false

    # Customize the amount of memory and CPUs on the VM:
    vb.memory = "12288"
    vb.cpus = 6

    # Name in VirtualBox
    vb.name = "dev-playground"

    # Expose a larger set of guest resolutions and prefer 1080p.
    vb.customize ["modifyvm", :id, "--graphicscontroller", "vmsvga"]
    vb.customize ["modifyvm", :id, "--vram", "128"]
    vb.customize ["setextradata", :id, "CustomVideoMode1", VIDEO_MODES[0]]
    vb.customize ["setextradata", :id, "CustomVideoMode2", VIDEO_MODES[1]]
    vb.customize ["setextradata", :id, "CustomVideoMode3", VIDEO_MODES[2]]
    vb.customize ["setextradata", :id, "CustomVideoMode4", VIDEO_MODES[3]]
    vb.customize ["setextradata", :id, "CustomVideoMode5", VIDEO_MODES[4]]
  end

  config.trigger.after :up do |trigger|
    trigger.name = "Set default guest resolution"
    trigger.run = {
      inline: "VBoxManage controlvm dev-playground setvideomodehint 1920 1080 32"
    }
  end

  # Bootstrap python, create user, and resolve potential conflicts
  config.vm.provision "shell", privileged: true do |shell|
    shell.inline = <<-SHELL
      #!/bin/bash
      /vagrant/vm-provision-shell.sh
    SHELL
  end

  # Ansible provisioning
  config.vm.provision "ansible" do |ansible|
    ansible.playbook = "playbook.yml"
    ansible.verbose = true
    ansible.extra_vars = {
      username: "haris"
    }
  end
end
